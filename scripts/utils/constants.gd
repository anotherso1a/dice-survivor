## 全局常量管理脚本
##
## 本脚本集中管理游戏中所有"魔法数字"（magic numbers），
## 所有在多处使用的常量统一存放在此处，修改一处即可全局生效，
## 避免将数字硬编码散落在各个脚本中，方便策划调参和后期维护。
## 使用方式：在其他脚本中通过 Constants.VIEWPORT_W 等方式访问。
##
## class_name 说明：
##   使用 class_name 后，此脚本会注册为全局类，可在整个项目中
##   直接通过类名引用，无需 preload 或 load，是工具类的标准写法。
##
class_name Constants  # 注册为全局类"Constants"，全项目可直接访问，无需 preload
extends RefCounted  # 继承 RefCounted，作为工具类无场景节点，仅提供静态常量和方法


# ========== 视口 ==========
# 视口尺寸（与 project.godot 中 display/window/size 保持一致）
# 游戏中多处需要引用屏幕尺寸，集中定义避免各脚本各自写死数字
const VIEWPORT_W: float = 1280.0  # 视口宽度（像素），与项目设置中窗口宽度保持一致
const VIEWPORT_H: float = 720.0  # 视口高度（像素），与项目设置中窗口高度保持一致


# ========== 出生系统 ==========
# 出生点距视口边缘内缩距离（避免贴边）
# 敌人出生后玩家有足够反应时间，不会一出生就在屏幕最边缘
const SPAWN_MARGIN: float = 60.0  # 出生点距视口四边的内缩距离（像素），防止敌人贴边生成
# 出生点距玩家最小安全距离（像素）
# 防止敌人直接出生在玩家脸上，给玩家反应和闪避时间
const MIN_PLAYER_DIST: float = 150.0  # 出生点距玩家的最小安全距离（像素），保障玩家生存空间
# 警告色块到敌人实际生成的延迟（秒）
# 给玩家看到黄色警告方块后、敌人出现前的预判时间
const WARNING_DURATION: float = 0.5  # 警告色块显示后、敌人实际生成的延迟时间（秒）


# ========== 骰子系统 ==========
# 玩家最大骰子槽位数
# 限制玩家同时持有的骰子数量上限，影响策略深度
const MAX_DICE_SLOTS: int = 6  # 玩家最大骰子槽位数，超过此数量无法再获得新骰子
# 骰子默认冷却时间（秒，备用）
# 单个骰子的基础攻击间隔，后续可能按骰子类型分别定义
const DEFAULT_COOLDOWN: float = 1.0  # 骰子默认冷却时间（秒），作为各类骰子的基础参考值


# ========== 敌人系统 ==========
# 默认刷怪间隔（秒，会在游戏中逐渐缩短）
# 控制游戏节奏，初始较宽松，随时间加快制造紧张感
const DEFAULT_SPAWN_INTERVAL: float = 2.0  # 初始刷怪间隔（秒），游戏开始时每 2 秒刷一只敌人
# 刷怪间隔下限（秒）
# 防止刷怪速度过快导致性能问题或玩家无法应对
const MIN_SPAWN_INTERVAL: float = 0.6  # 刷怪间隔下限（秒），即使后期也不会快于每 0.6 秒一只
# 每次刷怪间隔缩短量（秒）
# 随时间推移，刷怪间隔逐渐减少，难度递增
const SPAWN_INTERVAL_DELTA: float = 0.02  # 每次难度提升时，刷怪间隔减少的量（秒）


# ========== 玩家 ==========
# 玩家默认移动速度
# 影响操作手感，与敌人速度配合决定游戏难度
const PLAYER_MOVE_SPEED: float = 220.0  # 玩家默认移动速度（像素/秒）
# 玩家默认最大 HP
# 玩家初始和满血时的生命值上限
const PLAYER_MAX_HP: int = 100  # 玩家默认最大生命值


# ========== 敌人 ==========
# 敌人默认 HP
# 普通敌人的初始生命值，受玩家攻击扣除
const ENEMY_DEFAULT_HP: int = 6  # 敌人默认生命值，约需玩家攻击数次才能击杀
# 敌人默认移动速度
# 与玩家速度对比决定敌人是否能追上玩家
const ENEMY_DEFAULT_SPEED: float = 80.0  # 敌人默认移动速度（像素/秒），慢于玩家速度
# 敌人默认接触伤害
# 敌人与玩家碰撞时，每次造成的伤害量
const ENEMY_DEFAULT_CONTACT_DMG: int = 3  # 敌人默认接触伤害，每次碰撞扣 3 点 HP


# ========== UI ==========
# 伤害飘字持续时间（秒）
# 敌人或玩家受伤时，伤害数字从头顶飘出并渐隐的时长
const DAMAGE_NUMBER_DURATION: float = 0.6  # 伤害飘字在屏幕上显示并渐隐的总时长（秒）
# 受伤动画速度（fps）
# 角色受伤时播放被击动画的播放速率
const HURT_ANIM_SPEED: float = 5.0  # 受伤动画播放速度（帧/秒）
# 死亡动画速度（fps）
# 角色死亡时播放死亡动画的播放速率
const DEATH_ANIM_SPEED: float = 10.0  # 死亡动画播放速度（帧/秒）
